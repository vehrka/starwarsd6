<div class="starwarsd6 sheet actor character">
  <header class="sheet-header">
    <input type="text" name="name" value="{{document.name}}" placeholder="Character Name" />
    <div class="header-stats">
      <span class="cp-display" title="{{localize 'STARWARSD6.Character.CharacterPoints'}}">
        CP: <strong>{{system.characterPoints}}</strong>
      </span>
      <span class="fp-display" title="{{localize 'STARWARSD6.Character.ForcePoints'}}">
        FP: <strong>{{system.forcePoints}}</strong>
      </span>
      <button type="button" data-action="newRound" class="new-round-btn"
              title="{{localize 'STARWARSD6.Roll.NewRound'}}">
        {{localize "STARWARSD6.Roll.NewRound"}}
      </button>
    </div>
  </header>

  {{!-- Tab navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item {{#if (eq tabs.primary 'attributes')}}active{{/if}}"
       data-action="tab" data-tab="attributes" data-group="primary">
      {{localize "STARWARSD6.Tab.Attributes"}}
    </a>
    <a class="item {{#if (eq tabs.primary 'skills')}}active{{/if}}"
       data-action="tab" data-tab="skills" data-group="primary">
      {{localize "STARWARSD6.Tab.Skills"}}
    </a>
    <a class="item {{#if (eq tabs.primary 'inventory')}}active{{/if}}"
       data-action="tab" data-tab="inventory" data-group="primary">
      {{localize "STARWARSD6.Tab.Inventory"}}
    </a>
    <a class="item {{#if (eq tabs.primary 'combat')}}active{{/if}}"
       data-action="tab" data-tab="combat" data-group="primary">
      {{localize "STARWARSD6.Tab.Combat"}}
    </a>
  </nav>

  {{!-- ATTRIBUTES TAB --}}
  <section class="tab {{#if (eq tabs.primary 'attributes')}}active{{/if}}"
           data-tab="attributes" data-group="primary">
    <table class="attributes-table">
      <thead>
        <tr>
          <th>{{localize "STARWARSD6.Attribute.Label"}}</th>
          <th>{{localize "STARWARSD6.Attribute.Dice"}}</th>
          <th>{{localize "STARWARSD6.Attribute.Pips"}}</th>
          <th>{{localize "STARWARSD6.Attribute.BaseValue"}}</th>
          <th>{{localize "STARWARSD6.Roll.Label"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each attributeEntries as |attr|}}
        <tr>
          <td>{{localize attr.label}}</td>
          <td><input type="number" name="system.{{attr.key}}.dice" value="{{attr.dice}}" min="1" /></td>
          <td><input type="number" name="system.{{attr.key}}.pips" value="{{attr.pips}}" min="0" max="2" /></td>
          <td class="base-value">{{attr.baseValue}}</td>
          <td><button type="button" data-action="rollAttribute" data-attribute-key="{{attr.key}}">
            <i class="fas fa-dice"></i>
          </button></td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="character-stats">
      <div class="form-group">
        <label>{{localize "STARWARSD6.Attribute.Move"}}</label>
        <input type="number" name="system.move" value="{{system.move}}" min="0" />
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Character.HitBoxes"}}</label>
        <span class="derived-value">{{system.hitBoxes}}</span>
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Character.ForceSensitive"}}</label>
        <input type="checkbox" name="system.forceSensitive" {{#if system.forceSensitive}}checked{{/if}} />
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Character.CharacterPoints"}}</label>
        <input type="number" name="system.characterPoints" value="{{system.characterPoints}}" min="0" />
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Character.ForcePoints"}}</label>
        <input type="number" name="system.forcePoints" value="{{system.forcePoints}}" min="0" />
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Character.DarkSidePoints"}}</label>
        <input type="number" name="system.darkSidePoints" value="{{system.darkSidePoints}}" min="0" />
      </div>
    </div>

    <div class="wound-tracking">
      <div class="form-group">
        <label>{{localize "STARWARSD6.Wound.StunMarks"}}</label>
        <input type="number" name="system.stunMarks" value="{{system.stunMarks}}" min="0" />
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Wound.WoundMarks"}}</label>
        <input type="number" name="system.woundMarks" value="{{system.woundMarks}}" min="0" />
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Wound.IncapMarks"}}</label>
        <input type="number" name="system.incapMarks" value="{{system.incapMarks}}" min="0" />
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Wound.MortalMarks"}}</label>
        <input type="number" name="system.mortalMarks" value="{{system.mortalMarks}}" min="0" />
      </div>
    </div>
  </section>

  {{!-- SKILLS TAB --}}
  <section class="tab {{#if (eq tabs.primary 'skills')}}active{{/if}}"
           data-tab="skills" data-group="primary">
    {{#each attributeGroups as |group|}}
      <h3>{{localize group.label}}</h3>
      {{#if group.skills.length}}
        <table class="skills-table">
          <thead>
            <tr>
              <th>{{localize "STARWARSD6.Skill.Name"}}</th>
              <th>{{localize "STARWARSD6.Skill.Rank"}}</th>
              <th>{{localize "STARWARSD6.Skill.DicePool"}}</th>
              <th>{{localize "STARWARSD6.Roll.Label"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each group.skills as |skill|}}
            <tr class="item-row" data-item-id="{{skill.id}}">
              <td>{{skill.name}}</td>
              <td>{{skill.rank}}</td>
              <td>{{skill.dicePool}}D{{#if skill.pips}}+{{skill.pips}}{{/if}}</td>
              <td><button type="button" data-action="rollSkill" data-skill-id="{{skill.id}}">
                <i class="fas fa-dice"></i>
              </button></td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      {{else}}
        <p class="no-skills">—</p>
      {{/if}}
    {{/each}}

    {{#if forceSkills.length}}
      <h3>{{localize "STARWARSD6.ForceSkills"}}</h3>
      <table class="skills-table">
        <thead>
          <tr>
            <th>{{localize "STARWARSD6.Skill.Name"}}</th>
            <th>{{localize "STARWARSD6.Skill.DicePool"}}</th>
            <th>{{localize "STARWARSD6.Roll.Label"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each forceSkills as |skill|}}
          <tr class="item-row" data-item-id="{{skill.id}}">
            <td>{{skill.name}}</td>
            <td>{{skill.dicePool}}D{{#if skill.pips}}+{{skill.pips}}{{/if}}</td>
            <td><button type="button" data-action="rollSkill" data-skill-id="{{skill.id}}">
              <i class="fas fa-dice"></i>
            </button></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    {{/if}}
  </section>

  {{!-- INVENTORY TAB --}}
  <section class="tab {{#if (eq tabs.primary 'inventory')}}active{{/if}}"
           data-tab="inventory" data-group="primary">

    <h3>{{localize "STARWARSD6.Inventory.Weapons"}}</h3>
    {{#if weapons.length}}
      <table class="inventory-table">
        <thead>
          <tr>
            <th>{{localize "STARWARSD6.Skill.Name"}}</th>
            <th>{{localize "STARWARSD6.Item.Weapon.Damage"}}</th>
            <th>{{localize "STARWARSD6.Item.Weapon.AttackSkill"}}</th>
            <th>{{localize "STARWARSD6.Item.Weapon.Range"}}</th>
            <th>{{localize "STARWARSD6.Item.Equipped"}}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each weapons as |weapon|}}
          <tr class="item-row" data-item-id="{{weapon.id}}">
            <td>{{weapon.name}}</td>
            <td>{{weapon.damageDice}}D{{#if weapon.damagePips}}+{{weapon.damagePips}}{{/if}}</td>
            <td>{{weapon.attackSkill}}</td>
            <td>{{weapon.range}}</td>
            <td><button type="button" class="equip-toggle {{#if weapon.equipped}}equipped{{/if}}" data-action="toggleEquipped" data-item-id="{{weapon.id}}" title="{{localize 'STARWARSD6.Item.Equipped'}}">{{#if weapon.equipped}}✓{{else}}○{{/if}}</button></td>
            <td><button type="button" class="item-delete" data-action="deleteItem" data-item-id="{{weapon.id}}" title="Delete">✕</button></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="no-items">{{localize "STARWARSD6.Inventory.Empty"}}</p>
    {{/if}}

    <h3>{{localize "STARWARSD6.Inventory.Armor"}}</h3>
    {{#if armors.length}}
      <table class="inventory-table">
        <thead>
          <tr>
            <th>{{localize "STARWARSD6.Skill.Name"}}</th>
            <th>{{localize "STARWARSD6.Item.Armor.ArmorBonus"}}</th>
            <th>{{localize "STARWARSD6.Item.Equipped"}}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each armors as |armor|}}
          <tr class="item-row" data-item-id="{{armor.id}}">
            <td>{{armor.name}}</td>
            <td>{{armor.armorBonus}}</td>
            <td><button type="button" class="equip-toggle {{#if armor.equipped}}equipped{{/if}}" data-action="toggleEquipped" data-item-id="{{armor.id}}" title="{{localize 'STARWARSD6.Item.Equipped'}}">{{#if armor.equipped}}✓{{else}}○{{/if}}</button></td>
            <td><button type="button" class="item-delete" data-action="deleteItem" data-item-id="{{armor.id}}" title="Delete">✕</button></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="no-items">{{localize "STARWARSD6.Inventory.Empty"}}</p>
    {{/if}}

    <h3>{{localize "STARWARSD6.Inventory.Equipment"}}</h3>
    {{#if equipment.length}}
      <table class="inventory-table">
        <thead>
          <tr>
            <th>{{localize "STARWARSD6.Skill.Name"}}</th>
            <th>{{localize "STARWARSD6.Item.Equipment.Quantity"}}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each equipment as |eq|}}
          <tr class="item-row" data-item-id="{{eq.id}}">
            <td>{{eq.name}}</td>
            <td>{{eq.quantity}}</td>
            <td><button type="button" class="item-delete" data-action="deleteItem" data-item-id="{{eq.id}}" title="Delete">✕</button></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="no-items">{{localize "STARWARSD6.Inventory.Empty"}}</p>
    {{/if}}

  </section>

  {{!-- COMBAT TAB --}}
  <section class="tab {{#if (eq tabs.primary 'combat')}}active{{/if}}"
           data-tab="combat" data-group="primary">

    {{!-- Defense Values --}}
    <h3>{{localize "STARWARSD6.Combat.Defense"}}</h3>
    <table class="combat-defense-table">
      <thead>
        <tr>
          <th>{{localize "STARWARSD6.Combat.RangedDefense"}}</th>
          <th>{{localize "STARWARSD6.Combat.MeleeDefense"}}</th>
          <th>{{localize "STARWARSD6.Combat.BrawlingDefense"}}</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="defense-value">{{combatData.rangedDefense}}</td>
          <td class="defense-value">{{combatData.meleeDefense}}</td>
          <td class="defense-value">{{combatData.brawlingDefense}}</td>
        </tr>
      </tbody>
    </table>

    {{!-- Damage Thresholds --}}
    <h3>{{localize "STARWARSD6.Combat.DamageThresholds"}}</h3>
    <table class="combat-defense-table">
      <thead>
        <tr>
          <th>{{localize "STARWARSD6.Combat.Stun"}}</th>
          <th>{{localize "STARWARSD6.Combat.Wound"}}</th>
          <th>{{localize "STARWARSD6.Combat.Incap"}}</th>
          <th>{{localize "STARWARSD6.Combat.Mortal"}}</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="defense-value">{{combatData.thresholdStun}}</td>
          <td class="defense-value">{{combatData.thresholdWound}}</td>
          <td class="defense-value">{{combatData.thresholdIncap}}</td>
          <td class="defense-value">{{combatData.thresholdMortal}}</td>
        </tr>
      </tbody>
    </table>

    {{!-- Wound Penalties --}}
    <h3>{{localize "STARWARSD6.Combat.Penalties"}}</h3>
    <div class="combat-penalties">
      <div class="form-group">
        <label>{{localize "STARWARSD6.Combat.PenaltyDice"}}</label>
        <span class="derived-value">{{combatData.penaltyDice}}</span>
      </div>
      <div class="form-group">
        <label>{{localize "STARWARSD6.Combat.PenaltyPips"}}</label>
        <span class="derived-value">{{combatData.penaltyPips}}</span>
      </div>
    </div>

    {{!-- Hit Boxes --}}
    <h3>{{localize "STARWARSD6.Combat.HitBoxes"}}</h3>
    <div class="hit-box-tracker">

      <div class="hit-box-row">
        <span class="tier-label">{{localize "STARWARSD6.Combat.Stun"}}</span>
        <div class="hit-boxes">
          {{#each combatData.stunBoxes as |box|}}
          <button type="button" class="hit-box {{#if box.marked}}marked{{/if}}"
                  data-action="markHitBox" data-tier="stun"
                  title="{{localize "STARWARSD6.Combat.Stun"}}"></button>
          {{/each}}
        </div>
      </div>

      <div class="hit-box-row">
        <span class="tier-label">{{localize "STARWARSD6.Combat.Wound"}}</span>
        <div class="hit-boxes">
          {{#each combatData.woundBoxes as |box|}}
          <button type="button" class="hit-box {{#if box.marked}}marked{{/if}}"
                  data-action="markHitBox" data-tier="wound"
                  title="{{localize "STARWARSD6.Combat.Wound"}}"></button>
          {{/each}}
        </div>
      </div>

      <div class="hit-box-row">
        <span class="tier-label">{{localize "STARWARSD6.Combat.Incap"}}</span>
        <div class="hit-boxes">
          {{#each combatData.incapBoxes as |box|}}
          <button type="button" class="hit-box {{#if box.marked}}marked{{/if}}"
                  data-action="markHitBox" data-tier="incap"
                  title="{{localize "STARWARSD6.Combat.Incap"}}"></button>
          {{/each}}
        </div>
      </div>

      <div class="hit-box-row">
        <span class="tier-label">{{localize "STARWARSD6.Combat.Mortal"}}</span>
        <div class="hit-boxes">
          {{#each combatData.mortalBoxes as |box|}}
          <button type="button" class="hit-box {{#if box.marked}}marked{{/if}}"
                  data-action="markHitBox" data-tier="mortal"
                  title="{{localize "STARWARSD6.Combat.Mortal"}}"></button>
          {{/each}}
        </div>
      </div>

    </div>
    <p class="hit-box-hint">{{localize "STARWARSD6.Combat.HitBoxHint"}}</p>

    {{!-- Attack Rolls --}}
    <h3>{{localize "STARWARSD6.Combat.Weapons"}}</h3>
    {{#if combatData.weapons.length}}
      <table class="combat-weapons-table">
        <thead>
          <tr>
            <th>{{localize "STARWARSD6.Skill.Name"}}</th>
            <th>{{localize "STARWARSD6.Item.Weapon.Damage"}}</th>
            <th>{{localize "STARWARSD6.Item.Weapon.AttackSkill"}}</th>
            <th>{{localize "STARWARSD6.Combat.AttackRoll"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each combatData.weapons as |weapon|}}
          <tr>
            <td>{{weapon.name}}</td>
            <td>{{weapon.damageDice}}D{{#if weapon.damagePips}}+{{weapon.damagePips}}{{/if}}</td>
            <td>{{weapon.attackSkill}}</td>
            <td>
              <button type="button" data-action="rollAttack" data-weapon-id="{{weapon.id}}">
                {{localize "STARWARSD6.Combat.Roll"}}
              </button>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p class="no-items">{{localize "STARWARSD6.Inventory.Empty"}}</p>
    {{/if}}

  </section>
</div>
